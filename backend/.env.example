# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:&&&&@localhost:5432/smart_bureau_v
JWT_SECRET_KEY=replace-with-a-secure-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Broker MQTT (Mosquitto ou HiveMQ local) ────────────────────────────────────
# Laisser MQTT_HOST vide pour désactiver MQTT (mode dégradé sans IoT)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
